<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_RIGHT" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="335.0" spacing="20.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="fi.jyu.ohj2.kahepiip.listsapp.controller.EditRecipeController">
    <children>
        <Label alignment="CENTER" maxWidth="1.7976931348623157E308" text="EDIT RECIPE" VBox.vgrow="NEVER">
            <font>
                <Font size="14.0" />
            </font>
        </Label>
        <TextField fx:id="editNameTxt" promptText="Recipe name" />
        <ComboBox fx:id="editCategoryCombo" maxWidth="1.7976931348623157E308" promptText="Category" VBox.vgrow="NEVER" />
        <VBox spacing="10.0" VBox.vgrow="ALWAYS">
            <children>
                <TableView fx:id="editRecipeTable" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS" />
                <TextField fx:id="addingredientTxt" promptText="Ingredient name" />
                <HBox alignment="CENTER" spacing="10.0" VBox.vgrow="NEVER">
                    <children>
                        <TextField fx:id="addAmountTxt" maxWidth="1.7976931348623157E308" promptText="Amount" HBox.hgrow="ALWAYS" />
                        <ComboBox fx:id="addUnitCombo" promptText="Unit" HBox.hgrow="NEVER" />
                        <Button fx:id="addNewIngredientBtn" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" mnemonicParsing="false" onAction="#handleAddNewIngredientBtn" prefWidth="40.0" text="Add" HBox.hgrow="NEVER" />
                    </children>
                </HBox>
                <HBox alignment="CENTER" spacing="10.0" VBox.vgrow="NEVER">
                    <children>
                        <Button fx:id="saveEditedBtn" maxHeight="-Infinity" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleSaveEditedBtn" prefHeight="50.0" prefWidth="145.0" text="Save recipe" textAlignment="CENTER" HBox.hgrow="ALWAYS" />
                        <Button fx:id="saveAndAddBtn" maxHeight="-Infinity" mnemonicParsing="false" onAction="#handleSaveEditedAndAddBtn" prefHeight="50.0" prefWidth="145.0" text="Save and add to shopping list" textAlignment="CENTER" wrapText="true" HBox.hgrow="ALWAYS" />
                    </children>
                </HBox>
            </children>
        </VBox>
        <HBox alignment="CENTER_LEFT" VBox.vgrow="NEVER">
            <children>
                <VBox alignment="BOTTOM_LEFT" maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS">
                    <children>
                        <Button fx:id="removeIngredientBtn" mnemonicParsing="false" onAction="#handleRemoveIngredientBtn" text="Remove Ingredient" />
                    </children>
                </VBox>
                <VBox alignment="BOTTOM_RIGHT" maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS">
                    <children>
                        <Button fx:id="returnToRecipesBtn" mnemonicParsing="false" onAction="#handleReturnToRecipesBtn" text="Return" />
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</VBox>
