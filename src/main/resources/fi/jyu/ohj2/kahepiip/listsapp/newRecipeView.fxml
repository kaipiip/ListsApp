<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>


<VBox alignment="TOP_RIGHT" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="335.0" spacing="20.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="fi.jyu.ohj2.kahepiip.listsapp.controller.NewRecipeController">
   <children>
      <Label alignment="CENTER" maxWidth="1.7976931348623157E308" text="NEW RECIPE" VBox.vgrow="NEVER">
         <font>
            <Font size="14.0" />
         </font>
      </Label>
      <TextField fx:id="recipeNameTxt" promptText="Recipe name" />
      <ComboBox fx:id="categoryCombo" maxWidth="1.7976931348623157E308" onAction="#handleCategoryCombo" promptText="Category" VBox.vgrow="NEVER" />
      <VBox spacing="10.0" VBox.vgrow="ALWAYS">
         <children>
            <TableView fx:id="newRecipeTable" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
               <columns>
                  <TableColumn fx:id="amountColumn" maxWidth="1.7976931348623157E308" prefWidth="75.0" text="Amount" />
                  <TableColumn fx:id="unitColumn" maxWidth="1.7976931348623157E308" minWidth="50.0" prefWidth="50.0" text="Unit" />
                  <TableColumn fx:id="nameColumn" maxWidth="1.7976931348623157E308" minWidth="100.0" prefWidth="170.0" text="Ingredient name" />
               </columns>
            </TableView>
            <TextField fx:id="ingredientTxt" promptText="Ingredient name" />
            <HBox alignment="CENTER" spacing="10.0" VBox.vgrow="NEVER">
               <children>
                  <TextField fx:id="amountTxt" maxWidth="1.7976931348623157E308" promptText="Amount" HBox.hgrow="ALWAYS" />
                  <ComboBox fx:id="unitCombo" onAction="#handleUnitCombo" promptText="Unit" HBox.hgrow="NEVER" />
                  <Button fx:id="addIngredientBtn" mnemonicParsing="false" onAction="#handleAddIngredientBtn" text="Add" HBox.hgrow="NEVER" />
               </children>
            </HBox>
            <HBox alignment="CENTER" spacing="10.0" VBox.vgrow="NEVER">
               <children>
                  <Button fx:id="saveBtn" maxHeight="-Infinity" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleSaveBtn" prefHeight="50.0" prefWidth="145.0" text="Save recipe" textAlignment="CENTER" HBox.hgrow="ALWAYS" />
                  <Button fx:id="saveAndAddBtn" maxHeight="-Infinity" mnemonicParsing="false" onAction="#handleSaveAndAddBtn" prefHeight="50.0" prefWidth="145.0" text="Save and add to shopping list" textAlignment="CENTER" wrapText="true" HBox.hgrow="ALWAYS" />
               </children>
            </HBox>
         </children>
      </VBox>
      <Button fx:id="returnBtn" mnemonicParsing="false" onAction="#handleReturnBtn" text="Return" VBox.vgrow="NEVER" />
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</VBox>
