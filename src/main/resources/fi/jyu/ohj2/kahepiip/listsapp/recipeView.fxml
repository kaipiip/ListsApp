<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TreeView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>


<VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="335.0" spacing="20.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <Label alignment="CENTER" maxWidth="1.7976931348623157E308" text="RECIPES" VBox.vgrow="ALWAYS">
         <font>
            <Font size="14.0" />
         </font>
      </Label>
      <ComboBox fx:id="arrangeCombo" maxWidth="1.7976931348623157E308" onAction="#handleArrangeCombo" promptText="Arrange by:" VBox.vgrow="NEVER" />
      <VBox alignment="CENTER" spacing="10.0" VBox.vgrow="ALWAYS">
         <children>
            <TreeView fx:id="recipeTree" VBox.vgrow="ALWAYS" />
            <HBox spacing="10.0" VBox.vgrow="NEVER">
               <children>
                  <TextField fx:id="searchTxt" promptText="Recipe" HBox.hgrow="ALWAYS" />
                  <Button fx:id="searchBtn" mnemonicParsing="false" text="Search" />
               </children>
            </HBox>
            <Button fx:id="newRecipeBtn" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNewRecipeBtn" text="Create a New Recipe" VBox.vgrow="ALWAYS" />
         </children>
      </VBox>
      <HBox spacing="10.0" VBox.vgrow="NEVER">
         <children>
          <Button fx:id="removeBtn" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleRemoveBtn" text="Remove recipe" HBox.hgrow="ALWAYS" />
            <Button fx:id="editBtn" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleEditBtn" text="Edit recipe" HBox.hgrow="ALWAYS" />
            <Button fx:id="returnBtn" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleReturnBtn" text="Return" HBox.hgrow="ALWAYS" />
         </children>
      </HBox>
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</VBox>
